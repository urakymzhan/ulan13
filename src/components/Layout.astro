---
import '../styles/global.css';
const { title } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ? `${title} | Ulan Rakymzhanov` : 'Ulan Rakymzhanov'}</title>
</head>
<body>

  <button id="burger-btn" aria-label="Toggle menu">
    <img id="icon-open" src={`${BASE}assets/menu-open-50.png`} alt="open menu" />
    <img id="icon-close" src={`${BASE}assets/menu-close-64.png`} alt="close menu" />
  </button>

  <div id="layout">
    <nav id="sidebar">
      <div class="profile">
        <a href={BASE} class="profile-link">
          <img src={`${BASE}assets/profile.jpeg`} alt="profile picture" class="profile-img" />
          <p>Ulan Rakymzhanov</p>
          <p class="home-label">- home -</p>
        </a>
      </div>
      <ul class="nav-links">
        <li><a href={`${BASE}blogs`}>✍🏻 Blogs</a></li>
        <li><a href={`${BASE}projects`}>🛠️ Projects</a></li>
        <li><a href={`${BASE}videos`}>📺 Teaching Videos</a></li>
        <li><a href={`${BASE}certificates`}>📜 Qualifications</a></li>
        <li>
          <a href="https://www.goodreads.com/review/list/120002670-ulan-rakymzhanov?ref=nav_mybooks&shelf=read" target="_blank" rel="noreferrer">
            📚 Bookshelf
          </a>
        </li>
      </ul>
      <div class="sidebar-footer">
        <a href="https://www.linkedin.com/in/ulan-rakymzhanov/" target="_blank" rel="noreferrer">
          <img src={`${BASE}assets/linkedIn.svg`} class="footer-icon" alt="linkedin" />
        </a>
      </div>
    </nav>

    <main>
      <slot />
    </main>
  </div>

</body>
</html>

<script>
  const btn = document.getElementById('burger-btn');
  const sidebar = document.getElementById('sidebar');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function setOpen(open: boolean) {
    sidebar?.classList.toggle('open', open);
    if (iconOpen && iconClose) {
      (iconOpen as HTMLElement).style.display = open ? 'none' : 'block';
      (iconClose as HTMLElement).style.display = open ? 'block' : 'none';
      (iconClose as HTMLElement).style.background = open ? '#fff' : '';
    }
  }

  setOpen(false);

  btn?.addEventListener('click', () => {
    setOpen(!sidebar?.classList.contains('open'));
  });

  sidebar?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>

<style>
  /* ── Burger button — mobile only ── */
  #burger-btn {
    display: none;
    position: fixed;
    z-index: 10;
    left: 20px;
    top: 20px;
    width: 30px;
    height: 30px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  #burger-btn img {
    width: 100%;
    height: 100%;
  }

  /* ── Two-column layout ── */
  #layout {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  #sidebar {
    width: 250px;
    min-width: 250px;
    background-color: var(--mainBlack);
    color: var(--sidebarColor);
    font-size: var(--mainFont);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 40px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .profile {
    text-align: center;
    font-weight: bold;
    margin-bottom: 10px;
  }
  .profile-link {
    color: inherit;
    display: block;
    transition: color 0.4s linear;
  }
  .profile-link:hover {
    color: var(--yellowgreen);
  }
  .profile-link p {
    font-size: 14px;
    margin: 0;
  }
  .home-label {
    margin-top: 5px;
    color: var(--yellowgreen);
    transition: color 0.4s linear;
  }
  .profile-link:hover .home-label {
    color: var(--white);
  }
  .profile-img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 50%;
    margin-bottom: 10px;
    transition: 0.8s linear;
  }
  .profile-img:hover {
    transform: scale(1.05);
  }

  .nav-links {
    padding: 0;
    text-align: center;
    list-style: none;
    width: 100%;
  }
  .nav-links li {
    padding: 14px 0;
    color: var(--yellowgreen);
    transition: color 0.4s linear;
  }
  .nav-links li:hover {
    color: #fff;
  }
  .nav-links a {
    color: inherit;
    font-size: 16px;
  }

  .sidebar-footer {
    margin-top: auto;
    padding: 20px 0;
  }
  .footer-icon {
    width: 28px;
    height: 28px;
  }

  /* ── Main content ── */
  main {
    flex: 1;
    padding: 40px;
    min-height: 100vh;
  }

  /* ── Mobile: hide sidebar, show burger ── */
  @media (max-width: 768px) {
    #burger-btn {
      display: block;
    }

    #sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      min-width: unset;
      height: 100vh;
      z-index: 9;
      transform: translateX(-100%);
      transition: transform 0.3s ease-in;
      padding-top: 60px;
    }
    #sidebar.open {
      transform: translateX(0);
    }

    .nav-links a {
      font-size: 24px;
    }
    .nav-links li {
      padding: 18px 0;
    }

    main {
      padding: 20px;
      max-width: 100%;
    }
  }
</style>
