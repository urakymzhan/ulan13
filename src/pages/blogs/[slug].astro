---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogs = await getCollection('blogs');
  return blogs.map((blog) => ({
    params: { slug: blog.id.replace(/\.md$/, '') },
    props: { blog },
  }));
}

const { blog } = Astro.props;
const { Content } = await render(blog);
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={blog.data.title}>
  <div class="blog-wrapper">
    <div class="aligner">
      <a href={`${BASE}blogs`} class="page-nav-icon">&#8592; back</a>
    </div>
    <Content />
    <div class="aligner aligner-end">
      <button onclick="window.scrollTo(0,0)" class="page-nav-icon scroll-top">&#8593; top</button>
    </div>
  </div>
</Layout>

<style>
  .blog-wrapper {
    max-width: 70%;
    margin: 0 auto;
    font-family: var(--blogFont);
    text-align: left;
    color: var(--blogColor);
    padding-top: 20px;
    padding-bottom: 20px;
  }
  .blog-wrapper :global(h1),
  .blog-wrapper :global(h2),
  .blog-wrapper :global(h3),
  .blog-wrapper :global(h4) {
    color: var(--blogHeaderColor);
  }
  .blog-wrapper :global(em) {
    color: #118ab2;
    font-size: 0.8rem;
  }
  .blog-wrapper :global(strong) {
    font-weight: 900;
    color: #000;
  }
  .blog-wrapper :global(img) {
    width: 100%;
    max-height: 340px;
    object-fit: cover;
  }
  .aligner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .aligner-end {
    justify-content: flex-end;
  }
  .page-nav-icon {
    color: #4682b4;
    font-size: 18px;
    font-weight: 900;
    cursor: pointer;
    text-decoration: none;
  }
  .scroll-top {
    background: transparent;
    border: none;
    font-family: var(--font);
  }
  @media (max-width: 768px) {
    .blog-wrapper {
      max-width: 90%;
    }
  }
</style>
