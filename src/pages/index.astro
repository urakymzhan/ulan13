---
import Layout from '../components/Layout.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Home">
  <div class="home-wrapper">
    <div class="hero">
      <h1>Hi, I'm <span>Ulan</span></h1>
      <p class="tagline">Engineer &amp; Consultant</p>
      <p class="tagline-sub">Frontend · Backend · Mobile · AI</p>
    </div>

    <div class="about">
      <p>
        I turn ideas into products — from sleek frontends to scalable backends and AI integrations.
        Check out my <a href={`${BASE}projects`}>projects</a> or read my <a href={`${BASE}blogs`}>blog</a>.
      </p>
    </div>

    <div class="interests">
      <span>⛰️ hiking</span>
      <span>🏃 running</span>
      <span>⚽ soccer</span>
      <span>☕ coffee</span>
      <span>🎮 CS2</span>
    </div>
  </div>
</Layout>

<style>
  .home-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 60px;
  }

  .hero h1 {
    font-size: 2.8rem;
    margin: 0 0 8px;
    font-family: var(--font);
  }
  .hero h1 span {
    color: var(--darkred);
  }
  .tagline {
    font-size: 1.1rem;
    font-weight: bold;
    margin: 0;
    color: #333;
  }
  .tagline-sub {
    font-size: 0.85rem;
    color: gray;
    margin: 4px 0 0;
    letter-spacing: 0.05em;
  }

  .about p {
    font-size: 1rem;
    line-height: 1.7;
    color: #444;
    max-width: 520px;
    margin: 0;
  }
  .about a {
    font-weight: 900;
    color: var(--darkred);
  }
  .about a:hover {
    text-decoration: underline;
  }

  .interests {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .interests span {
    background: #f4f4f4;
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 0.85rem;
    color: #444;
  }
</style>
