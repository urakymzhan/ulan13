---
import Layout from '../components/Layout.astro';
import { teachingVideos } from '../data/dataStore.js';
---

<Layout title="Teaching Videos">
  <div class="videos-wrapper">
    <h4>Some of my teachings [end of 2019] [new ones are private]</h4>
    {teachingVideos.map((group) => (
      <section>
        <h1>{group.concept}</h1>
        {group.videos.map((video) => (
          <div>
            <h5>{video.title}</h5>
            <iframe
              class="front-end-video"
              title="teaching video"
              width="560"
              height="315"
              src={video.source}
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        ))}
      </section>
    ))}
  </div>
</Layout>

<style>
  .videos-wrapper {
    padding: 10px;
    text-align: center;
  }
  .videos-wrapper h1 {
    margin-top: 60px;
    text-transform: uppercase;
  }
  .videos-wrapper h5 {
    text-shadow: 1px 1px 10px rgb(255, 255, 255);
    margin-bottom: 5px;
  }
  .videos-wrapper section {
    text-align: center;
  }
  .videos-wrapper h4 {
    margin-top: 8px;
    color: #f43688;
  }
  .front-end-video {
    border: 6px solid #2F4F4F;
    width: 55%;
    height: 300px;
  }
  @media (max-width: 700px) {
    .videos-wrapper {
      padding-bottom: 40px;
    }
    .front-end-video {
      width: 100%;
      height: 200px;
    }
    .videos-wrapper h4 {
      font-size: 10px;
    }
  }
</style>
